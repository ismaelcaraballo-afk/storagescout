# StorageScout - Environment Variables Template
# 
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env to git - it's already in .gitignore
#
# Get credentials:
# - WattTime: https://www.watttime.org/api-documentation/
# - Electricity Maps: https://www.electricitymaps.com/api
#

# WattTime API Credentials (for real-time carbon intensity)
WATTTIME_USERNAME=your_username_here
WATTTIME_PASSWORD=your_password_here
WATTTIME_EMAIL=your_email@example.com
WATTTIME_ORG=your_organization_here

# Electricity Maps API Token (for carbon intensity levels)
ELECTRICITYMAPS_TOKEN=your_token_here
